{
  "name": "metrack-habit-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "android:permissions": "node scripts/ensure-android-reminder-permissions.mjs",
    "android:init": "npx cap add android && npm run android:permissions",
    "android:sync": "npm run android:permissions && npx cap sync android",
